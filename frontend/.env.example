# Deployed contract address (Celo mainnet)
# Purchase treasury is hardcoded in src/blockchain/tokens.js to match Blokaz
# and avoid MiniPay production env drift.
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RPC_URL=https://forno.celo.org

# Web3Auth — https://dashboard.web3auth.io
VITE_WEB3AUTH_CLIENT_ID=your_client_id_here
VITE_WEB3AUTH_NETWORK=sapphire_mainnet

# Backend API
VITE_API_URL=http://localhost:3001
